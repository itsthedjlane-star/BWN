generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  MEMBER
}

enum BetResult {
  PENDING
  WON
  LOST
  VOID
}

enum Sport {
  FOOTBALL
  HORSE_RACING
  GREYHOUND_RACING
  CRICKET
  TENNIS
  DARTS
  GOLF
}

enum TipsterSource {
  OLBG
  TIPSTRR
  FREE_SUPER_TIPS
  KICKOFF
  RATED_TIPSTERS
  SEED
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

// NextAuth models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Application models
model User {
  id              String    @id @default(cuid())
  name            String?
  email           String?   @unique
  emailVerified   DateTime?
  image           String?
  role            Role      @default(MEMBER)
  inviteCode      String?
  approved        Boolean   @default(false)
  ageConfirmedAt  DateTime?
  policyAcceptedAt    DateTime?
  policyVersionAccepted String?
  joinedAt        DateTime  @default(now())

  accounts   Account[]
  sessions   Session[]
  tips       Tip[]
  comments   Comment[]
  bets       Bet[]
  strategies Strategy[]
  tails      Tail[]
}

model Tip {
  id         String    @id @default(cuid())
  authorId   String
  sport      Sport
  event      String
  pick       String
  reasoning  String    @db.Text
  odds       String
  oddsDecimal Float?
  confidence Int       @default(3) // 1-5
  stake      Float     @default(1) // units
  source     String?   // external tipster source
  result     BetResult @default(PENDING)
  pnl        Float?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  author   User      @relation(fields: [authorId], references: [id])
  comments Comment[]
  tails    Tail[]
  bets     Bet[]
}

model Comment {
  id        String   @id @default(cuid())
  tipId     String
  authorId  String
  content   String   @db.Text
  createdAt DateTime @default(now())

  tip    Tip  @relation(fields: [tipId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id])
}

model Tail {
  id        String   @id @default(cuid())
  tipId     String
  userId    String
  createdAt DateTime @default(now())

  tip  Tip  @relation(fields: [tipId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  @@unique([tipId, userId])
}

model Bet {
  id        String    @id @default(cuid())
  userId    String
  tipId     String?   // null if manually logged
  tipsterTipId String? // optional: which external tipster tip influenced this bet
  sport     Sport
  event     String
  pick      String
  odds      String
  oddsDecimal Float?
  stake     Float     @default(1)
  result    BetResult @default(PENDING)
  pnl       Float?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user       User        @relation(fields: [userId], references: [id])
  tip        Tip?        @relation(fields: [tipId], references: [id])
  tipsterTip TipsterTip? @relation(fields: [tipsterTipId], references: [id])

  @@index([tipsterTipId])
}

model Strategy {
  id         String   @id @default(cuid())
  title      String
  slug       String   @unique
  sport      Sport?
  contentMdx String   @db.Text
  authorId   String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  author User @relation(fields: [authorId], references: [id])
}

model InviteCode {
  id        String   @id @default(cuid())
  code      String   @unique
  used      Boolean  @default(false)
  usedBy    String?
  createdAt DateTime @default(now())

  applications InviteApplication[] @relation("IssuedFromApplication")
}

// Public-facing apply-for-invite requests. Collected on the landing
// page, reviewed by admins, and (if approved) turned into an
// InviteCode row that's emailed back to the applicant out-of-band.
model InviteApplication {
  id           String            @id @default(cuid())
  email        String
  reason       String            @db.Text
  source       String?           // "how did you hear about us"
  status       ApplicationStatus @default(PENDING)
  reviewNotes  String?           @db.Text
  reviewedAt   DateTime?
  reviewedBy   String?           // admin user id
  inviteCodeId String?           // if APPROVED, the code we minted
  createdAt    DateTime          @default(now())

  inviteCode InviteCode? @relation("IssuedFromApplication", fields: [inviteCodeId], references: [id])

  @@index([email, createdAt])
  @@index([status, createdAt])
}

model Tipster {
  id          String        @id @default(cuid())
  source      TipsterSource
  externalId  String
  slug        String        @unique
  name        String
  sport       Sport?
  profileUrl  String?
  roi         Float?
  strikeRate  Float?
  totalTips   Int           @default(0)
  profitPts   Float?
  activeSince DateTime?
  form10      String?
  sourceRank  Int?
  lastSeenAt  DateTime      @default(now())
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  tips TipsterTip[]

  @@unique([source, externalId])
  @@index([sport, roi])
  @@index([source, roi])
}

model TipsterTip {
  id           String    @id @default(cuid())
  tipsterId    String
  externalId   String?
  sport        Sport
  event        String
  selection    String
  oddsAtTip    String
  oddsDecimal  Float?
  eventStartAt DateTime?
  postedAt     DateTime  @default(now())
  result       BetResult @default(PENDING)
  profitLoss   Float?
  sourceUrl    String?

  tipster Tipster @relation(fields: [tipsterId], references: [id], onDelete: Cascade)
  bets    Bet[]

  @@unique([tipsterId, externalId])
  @@index([sport, postedAt])
  @@index([postedAt])
  @@index([result])
}

// Keyed bearer tokens for server-to-server agent access. The token
// handed to callers is `<id>.<secret>`; we store only a SHA-256 hash
// of the secret so a DB read cannot recover usable tokens. Replaces
// the single-shared BWN_AGENT_TOKEN — that env var is still honoured
// as a legacy fallback but should be retired once all agents migrate.
model AgentKey {
  id           String    @id @default(cuid())
  name         String
  hashedSecret String
  scopes       String[]
  createdAt    DateTime  @default(now())
  lastUsedAt   DateTime?
  revokedAt    DateTime?
  notes        String?

  @@index([revokedAt])
}

// Logged when a user clicks a "Bet now" affiliate link. Powers simple
// per-surface CTR analytics without shipping a client-side tracker.
model OutboundClick {
  id         String   @id @default(cuid())
  userId     String?
  bookmaker  String
  context    String   // "odds" | "tip" | "tracker"
  ref        String?  // event id, tip id, etc.
  createdAt  DateTime @default(now())

  @@index([bookmaker, createdAt])
  @@index([context, createdAt])
}

// Price-over-time snapshots written by the odds cron. Fuels the
// comparison-page sparklines and the upcoming odds-drop alert triggers.
// Kept denormalised (no FK to any event/bookmaker table) because the
// Odds API is the source of truth for event identity and we don't
// persist events themselves.
model OddsSnapshot {
  id        String   @id @default(cuid())
  eventId   String   // Odds API event id
  sportKey  String   // raw Odds API sport key (e.g. "soccer_epl")
  bookmaker String   // lowercased bookmaker key (e.g. "bet365")
  market    String   // "h2h", "outrights", etc.
  outcome   String   // outcome name (e.g. "Arsenal", "Scottie Scheffler")
  price     Float    // decimal odds
  at        DateTime @default(now())

  @@index([eventId, at])
  @@index([eventId, bookmaker, outcome, at])
  @@index([at])
}
