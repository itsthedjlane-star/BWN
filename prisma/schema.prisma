generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  MEMBER
}

enum BetResult {
  PENDING
  WON
  LOST
  VOID
}

enum Sport {
  FOOTBALL
  HORSE_RACING
  GREYHOUND_RACING
  CRICKET
  TENNIS
  DARTS
  GOLF
}

// NextAuth models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Application models
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          Role      @default(MEMBER)
  inviteCode    String?
  approved      Boolean   @default(false)
  joinedAt      DateTime  @default(now())

  accounts   Account[]
  sessions   Session[]
  tips       Tip[]
  comments   Comment[]
  bets       Bet[]
  strategies Strategy[]
  tails      Tail[]
}

model Tip {
  id         String    @id @default(cuid())
  authorId   String
  sport      Sport
  event      String
  pick       String
  reasoning  String    @db.Text
  odds       String
  oddsDecimal Float?
  confidence Int       @default(3) // 1-5
  stake      Float     @default(1) // units
  source     String?   // external tipster source
  result     BetResult @default(PENDING)
  pnl        Float?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  author   User      @relation(fields: [authorId], references: [id])
  comments Comment[]
  tails    Tail[]
  bets     Bet[]
}

model Comment {
  id        String   @id @default(cuid())
  tipId     String
  authorId  String
  content   String   @db.Text
  createdAt DateTime @default(now())

  tip    Tip  @relation(fields: [tipId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id])
}

model Tail {
  id        String   @id @default(cuid())
  tipId     String
  userId    String
  createdAt DateTime @default(now())

  tip  Tip  @relation(fields: [tipId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  @@unique([tipId, userId])
}

model Bet {
  id        String    @id @default(cuid())
  userId    String
  tipId     String?   // null if manually logged
  sport     Sport
  event     String
  pick      String
  odds      String
  oddsDecimal Float?
  stake     Float     @default(1)
  result    BetResult @default(PENDING)
  pnl       Float?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id])
  tip  Tip? @relation(fields: [tipId], references: [id])
}

model Strategy {
  id         String   @id @default(cuid())
  title      String
  slug       String   @unique
  sport      Sport?
  contentMdx String   @db.Text
  authorId   String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  author User @relation(fields: [authorId], references: [id])
}

model InviteCode {
  id        String   @id @default(cuid())
  code      String   @unique
  used      Boolean  @default(false)
  usedBy    String?
  createdAt DateTime @default(now())
}
