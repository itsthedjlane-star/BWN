# Copy to .env.local and fill in. Anything unset is either optional or
# has a safe dev fallback (mock data, disabled feature).

# ───── Database ─────
DATABASE_URL="postgresql://..."

# ───── NextAuth ─────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# ───── Discord OAuth ─────
DISCORD_CLIENT_ID=""
DISCORD_CLIENT_SECRET=""
DISCORD_TIP_WEBHOOK_URL=""

# ───── Odds data ─────
# Get a key at https://the-odds-api.com (free tier available).
# Without this, /odds and /racing serve mock data in dev and empty arrays
# in prod.
ODDS_API_KEY=""

# Set to "1" to transparently substitute mock odds whenever the live feed
# is unavailable (no key, quota exhausted, unknown sport). Useful for
# demos/investor walkthroughs pre-launch so every tab shows sample data.
# Leave unset (or "0") in any deployment where real users might place
# real bets based on what they see.
# DEMO_MODE="1"

# ───── Agent / cron auth ─────
BWN_AGENT_TOKEN=""
CRON_SECRET=""

# ───── Tipster scrapers (disabled by default) ─────
# Set any of these to "1" to enable. SEED is for dev only.
TIPSTER_SOURCE_SEED="1"
# TIPSTER_SOURCE_OLBG="1"
# TIPSTER_SOURCE_TIPSTRR="1"
# TIPSTER_SOURCE_FREE_SUPER_TIPS="1"
# TIPSTER_SOURCE_KICKOFF="1"
# TIPSTER_SOURCE_RATED_TIPSTERS="1"

# ───── Bookmaker affiliate links ─────
# Each template is the affiliate URL with optional placeholders:
#   {event}     — Odds API event id
#   {market}    — market key (e.g. "h2h")
#   {selection} — outcome name
# Missing vars fall back to the bookmaker's homepage (still a valid link,
# just without tracking). Do NOT commit real tracking IDs — use .env.local.
BOOKMAKER_AFFILIATE_BET365=""
BOOKMAKER_AFFILIATE_WILLIAMHILL=""
BOOKMAKER_AFFILIATE_SKYBET=""
BOOKMAKER_AFFILIATE_PADDYPOWER=""
BOOKMAKER_AFFILIATE_BETFAIR=""
BOOKMAKER_AFFILIATE_LADBROKES=""
BOOKMAKER_AFFILIATE_CORAL=""
BOOKMAKER_AFFILIATE_BETWAY=""
BOOKMAKER_AFFILIATE_UNIBET=""
BOOKMAKER_AFFILIATE_888SPORT=""
